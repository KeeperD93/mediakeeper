# MediaKeeper backend/runtime configuration
#
# Every variable below is read by the backend at startup or runtime.
# Commented-out lines are optional overrides; uncommented lines are the
# defaults used by Docker Compose. Refer to docs/operations/ for full
# context on TLS, monitoring and backup configuration.

# ── Secrets / auth ──────────────────────────────────────────────────────
# Auto-generated on first launch in /data/.jwt_secret when left unset.
# Set it explicitly only if you manage the secret externally; it must be at
# least 32 random bytes. If you uncomment the line below and keep this
# placeholder value, the app refuses to boot.
# JWT_SECRET_KEY=change-me-with-at-least-32-random-bytes
JWT_EXPIRE_MINUTES=60
MK_ADMIN_USERS=admin

# ── Fernet encryption (sensitive settings at rest) ──────────────────────
# Auto-generated on first launch in /data/.encryption_key when neither
# variable is set. Override only if you maintain the key externally.
# MEDIAKEEPER_ENCRYPTION_KEY=
# MEDIAKEEPER_ENCRYPTION_KEY_FILE=/data/.encryption_key

# ── Frontend / cookies ──────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Reverse-proxy trust (CSV of CIDR or IPs) ────────────────────────────
# When empty, X-Forwarded-* headers are ignored entirely (failsafe for
# direct LAN exposure). Set to the CIDR of your reverse proxy to honour
# X-Forwarded-For, X-Forwarded-Proto and X-Forwarded-Host. Examples:
#   TRUSTED_PROXIES=127.0.0.1
#   TRUSTED_PROXIES=127.0.0.1,172.18.0.0/16
# See docs/operations/tls-deployment.md for the full picture.
TRUSTED_PROXIES=

# ── Content-Security-Policy mode ────────────────────────────────────────
# Defaults to enforce. Use report-only for transition periods (the policy
# is evaluated by the browser but not blocked). MK_DEBUG=true disables CSP
# entirely to keep Vite HMR working.
# MK_CSP_MODE=enforce

# ── Dev / debug mode ────────────────────────────────────────────────────
# MK_DEBUG=true relaxes CSP, allows Vite proxy and prints verbose boot
# diagnostics. Never leave it on in production.
MK_DEBUG=false

# ── Process role (set by entrypoint.sh, override only for orchestration) ─
# combined | web | worker. Default "combined" runs API + background tasks
# in one process. The Docker entrypoint sets "web" + "worker" when
# MK_SEPARATE_BACKGROUND_WORKER=true (recommended for production).
# MK_PROCESS_ROLE=combined
MK_SEPARATE_BACKGROUND_WORKER=true

# ── Database ────────────────────────────────────────────────────────────
# DATABASE_URL is auto-derived from /data/.pg_password on single-container
# deployments. Set explicitly only if pointing at an external Postgres.
# DATABASE_URL=
# DATABASE_SSL=false

# ── DB schema policy ────────────────────────────────────────────────────
# validate   : refuses to start if the expected schema is not present.
# create_all : only for one-off bootstrap/dev, never for a stable release.
MK_DB_SCHEMA_MODE=validate

# ── Environment marker ──────────────────────────────────────────────────
# Controls the strictness of boot-time validation (achievements seed,
# config sanity checks). Leave empty for dev, set to "production" on
# real deployments.
# ENV=production

# ── External services ───────────────────────────────────────────────────
TMDB_API_KEY=
TMDB_LANGUAGE=fr-FR
VERIFY_SSL=true
# IMGUR_CLIENT_ID=

# ── Filesystem ──────────────────────────────────────────────────────────
MEDIAKEEPER_PATH_ROOTS=
BACKUP_PATH=
LOG_DIR=
# Backup upload size cap (default 512 MiB). Raise carefully — each restore
# reads the whole ZIP into memory.
# BACKUP_UPLOAD_MAX_BYTES=536870912

# ── Caches ──────────────────────────────────────────────────────────────
# DNS cache TTL for the portal image proxy (default 300 s).
# MK_DNS_CACHE_TTL_SECONDS=300
# Image cache directory for portal media thumbnails.
# MK_IMAGE_CACHE_DIR=/data/cache/images

# ── Monitoring (Discord-compatible webhook for runtime alerts) ──────────
# Receives alerts for DB down, scheduler crash, background loop crash,
# backup failure, DB pool saturation. Leave empty to disable.
# See docs/operations/monitoring.md for the full catalogue.
MK_DISCORD_ALERT_WEBHOOK=
