# Mediakeeper backend/runtime configuration

# Secrets / auth
JWT_SECRET_KEY=change-me-with-at-least-32-random-bytes
MK_ADMIN_USERS=admin

# Frontend / cookies
FRONTEND_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Reverse-proxy trust (CSV of CIDR or IPs). When empty, X-Forwarded-*
# headers are ignored entirely (failsafe for direct LAN exposure).
# Set to the CIDR of your reverse proxy to honour X-Forwarded-For,
# X-Forwarded-Proto and X-Forwarded-Host. Examples:
#   TRUSTED_PROXIES=127.0.0.1
#   TRUSTED_PROXIES=127.0.0.1,172.18.0.0/16
# See docs/operations/tls-deployment.md for the full picture.
TRUSTED_PROXIES=

# Content-Security-Policy mode. Defaults to enforce. Use report-only for
# transition periods (the policy is evaluated by the browser but not
# blocked). MK_DEBUG=true disables CSP entirely to keep Vite HMR working.
# MK_CSP_MODE=enforce

# External services
TMDB_API_KEY=
VERIFY_SSL=true

# Filesystem / background worker
MEDIAKEEPER_PATH_ROOTS=
BACKUP_PATH=
MK_SEPARATE_BACKGROUND_WORKER=true

# Database schema policy
MK_DB_SCHEMA_MODE=validate

# Optional logging override
LOG_DIR=

# Monitoring — webhook receiving runtime alerts (DB down, scheduler crash,
# background loop crash, backup failure, DB pool saturation).
# Leave empty to disable. Format: Discord-compatible incoming-webhook URL.
# See docs/operations/monitoring.md for the full catalogue.
MK_DISCORD_ALERT_WEBHOOK=
