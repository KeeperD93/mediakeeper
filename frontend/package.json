{
  "name": "mediakeeper-frontend",
  "version": "1.0.0-rc.4",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "check": "node scripts/check-integrity.mjs && vite build",
    "i18n:check": "node scripts/check-i18n.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run check",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{js,vue}\"",
    "lint:fix": "eslint \"src/**/*.{js,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,json}\"",
    "stylelint": "stylelint \"src/**/*.{css,vue}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,vue}\" --fix",
    "typecheck": "vue-tsc --noEmit",
    "types:api": "node scripts/generate-api-types.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,vue}": [
      "stylelint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "uuid": "^14.0.0",
    "esbuild": "^0.28.1",
    "@redocly/openapi-core": {
      "js-yaml": "4.2.0"
    },
    "cosmiconfig": {
      "js-yaml": "4.2.0"
    }
  },
  "dependencies": {
    "@primevue/themes": "^4.3.1",
    "@tiptap/core": "^2.10.3",
    "@tiptap/extension-color": "^2.10.3",
    "@tiptap/extension-highlight": "^2.10.3",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-table": "^2.10.3",
    "@tiptap/extension-table-cell": "^2.10.3",
    "@tiptap/extension-table-header": "^2.10.3",
    "@tiptap/extension-table-row": "^2.10.3",
    "@tiptap/extension-text-align": "^2.10.3",
    "@tiptap/extension-text-style": "^2.10.3",
    "@tiptap/extension-underline": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "@tiptap/vue-3": "^2.10.3",
    "chart.js": "^4.4.7",
    "dompurify": "^3.4.11",
    "grid-layout-plus": "^1.0.5",
    "lucide-vue-next": "^1.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "autocannon": "^8.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.4.0",
    "lint-staged": "^17.0.8",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.16",
    "postcss-html": "^1.8.1",
    "prettier": "^3.9.1",
    "storybook": "^10.4.6",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  }
}
