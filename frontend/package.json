{
  "name": "mediakeeper-frontend",
  "version": "0.9.8",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node scripts/check-integrity.mjs && vite build",
    "i18n:check": "node scripts/check-i18n.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run check",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{js,vue}\"",
    "lint:fix": "eslint \"src/**/*.{js,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,json}\"",
    "stylelint": "stylelint \"src/**/*.{css,vue}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,vue}\" --fix",
    "typecheck": "vue-tsc --noEmit",
    "types:api": "node scripts/generate-api-types.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,vue}": [
      "stylelint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "dependencies": {
    "@primevue/themes": "^4.3.1",
    "@tiptap/core": "^2.10.3",
    "@tiptap/extension-color": "^2.10.3",
    "@tiptap/extension-highlight": "^2.10.3",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-table": "^2.10.3",
    "@tiptap/extension-table-cell": "^2.10.3",
    "@tiptap/extension-table-header": "^2.10.3",
    "@tiptap/extension-table-row": "^2.10.3",
    "@tiptap/extension-text-align": "^2.10.3",
    "@tiptap/extension-text-style": "^2.10.3",
    "@tiptap/extension-underline": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "@tiptap/vue-3": "^2.10.3",
    "chart.js": "^4.4.7",
    "dompurify": "^3.4.2",
    "grid-layout-plus": "^1.0.5",
    "lucide-vue-next": "^1.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.33",
    "vue-i18n": "^9.14.0",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "autocannon": "^8.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.2.0",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.13",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.10.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "~6.4.2",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
