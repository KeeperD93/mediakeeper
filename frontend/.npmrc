# Required for @intlify/unplugin-vue-i18n@4 with vue-i18n@9 on Vue 3.
# The unplugin declares a peerOptional dependency on vue-i18n-bridge,
# which transitively pulls @vue/composition-api targeting Vue 2.5-2.7
# and triggers an ERESOLVE conflict against this project's Vue 3.5 stack.
# Standard workaround documented by intlify/vue-i18n issue #1399.
#
# Remove this file when bumping to vue-i18n@11 + @intlify/unplugin-vue-i18n@6
# (the v6 unplugin drops the bridge peerOptional and works natively on Vue 3
# without the legacy-peer-deps escape hatch).
legacy-peer-deps=true
