# ============================================
# MediaKeeper — .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
.venv/
.venv-audit/
.venv-test/
venv/
env/

# pytest workspace temp dir (tests/conftest workspace_tmp_path) — local artifact.
backend/.pytest-temp/

# ---------- Node / Frontend ----------
node_modules/
frontend/dist/
frontend/.vite/
.npm
*.tgz

# ---------- Données & secrets ----------
*.db
*.sqlite
*.sqlite3
/data/
.env
.env.*
!.env.example

# Secrets auto-générés par le container
.pg_password
.jwt_secret

# ---------- Docker (volumes locaux) ----------
docker-compose.override.yml

# ---------- IDE / OS ----------
.vscode/
.idea/
.claude/
.aiignore
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- Logs & backups ----------
# Anchored on purpose: an unanchored ``logs/`` would also exclude code
# packages such as ``backend/services/logs/``, which is application code,
# not runtime log files. Same reasoning for ``backups/``.
*.log
/logs/
/backend/logs/
/backups/
/backend/backups/

# ---------- Audits locaux (workflow IA, hors périmètre public) ----------
audits/

# ---------- Communication / Growth (playbook interne, hors périmètre public) ----------
# Anchored: only the top-level ``comms/`` strategy workspace.
/comms/

# ---------- Tests ----------
.pytest_cache/
htmlcov/
coverage/
frontend/coverage/
coverage.xml
backend/coverage.xml
.coverage
.ruff_cache/
.mypy_cache/
pytest-cache-files-*/

# ---------- Audit / QA tool outputs ----------
.audit-tmp/
playwright-report/
test-results/
frontend/playwright-report/
frontend/test-results/
frontend/.lighthouseci/
.semgrep/

# ---------- Drafts personnels (à arbitrer) ----------
recap-mediakeeper-v1.md
ROADMAP.md
Rules.md

# ---------- Workshop (outil dev jetable, hors périmètre prod) ----------
frontend/src/views/portal/TrophyWorkshop.vue
frontend/src/composables/portal/useTrophyWorkshopMocks.js
frontend/src/composables/portal/useTrophyWorkshopPrompt.js
frontend/src/assets/styles/portal/trophy-workshop-fx-*.css

# ---------- Drill workspace (Batch 2C, restore drill, jetable, contient des secrets) ----------
# Anchored: only the top-level ``drill/`` workspace, not any future
# ``backend/.../drill/`` test fixtures.
/drill/

*storybook.log
storybook-static
